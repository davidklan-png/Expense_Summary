<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ report_title }}</title>
    <style>
        @page {
            size: A4 portrait;
            margin: 8mm 7mm;
        }
        body {
            font-family: 'Noto Sans CJK JP', 'Meiryo', 'Arial', sans-serif;
            margin: 0;
            background-color: #fff;
            color: #222;
            font-size: 8px;
            line-height: 1.35;
        }
        .container {
            width: 100%;
            margin: 0;
            background-color: white;
            padding: 0;
            border-radius: 0;
            box-shadow: none;
        }
        h1 {
            color: #333;
            border-bottom: 3px solid #0066cc;
            padding-bottom: 10px;
        }
        h2 {
            color: #0066cc;
            margin-top: 8mm;
            margin-bottom: 3mm;
            font-size: 13px;
        }
        .metadata {
            background-color: #f7f7f7;
            padding: 7mm 4mm;
            min-height: 44mm;
            margin-bottom: 3mm;
            white-space: pre-wrap;
            font-family: 'Noto Sans CJK JP', 'Meiryo', 'Arial', sans-serif;
            font-size: 7px;
        }
        .metadata p {
            margin: 0 0 8mm 0;
            color: #666;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 0;
            font-size: 7px;
            table-layout: fixed;
            page-break-inside: auto;
        }
        th, td {
            border: 0.5px solid #cfcfcf;
            padding: 3px 4px;
            text-align: left;
            vertical-align: middle;
            overflow-wrap: anywhere;
            word-break: break-word;
            line-break: strict;
            white-space: normal;
        }
        th {
            background-color: #0066cc;
            color: white;
            font-weight: bold;
            font-size: 7px;
        }
        th.attendee-group-header {
            background-color: #0052a3;
            text-align: center;
            font-size: 6.5px;
            padding: 3px;
        }
        th.attendee-subheader {
            background-color: #0066cc;
            text-align: center;
            font-size: 6px;
            padding: 3px;
        }
        thead {
            display: table-header-group;
        }
        tr {
            page-break-inside: avoid;
        }
        tbody tr:nth-child(even) {
            background-color: #fafafa;
        }
        .amount {
            text-align: right;
            font-family: 'Noto Sans Mono CJK JP', 'Courier New', monospace;
            white-space: nowrap;
        }
        .num,
        .id-value {
            text-align: center;
            white-space: nowrap;
        }
        .date-col {
            width: 7%;
        }
        .item-col {
            width: 31%;
        }
        .payment-col {
            width: 7%;
        }
        .amount-col {
            width: 7%;
        }
        .subject-col {
            width: 20%;
        }
        .count-col {
            width: 3%;
        }
        .participant-id-col {
            width: 2.25%;
        }
        .notes-col {
            width: 7%;
        }
        .attendee-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 0;
            font-size: 8px;
            table-layout: fixed;
        }
        .attendee-table th {
            background-color: #0066cc;
            color: white;
            font-weight: bold;
            padding: 4px;
            text-align: left;
        }
        .attendee-table td {
            border: 0.5px solid #cfcfcf;
            padding: 4px;
            text-align: left;
        }
        .attendee-table tbody tr:nth-child(even) {
            background-color: #fafafa;
        }
        .attendee-table .id-col {
            font-weight: bold;
            color: #0066cc;
            width: 8%;
        }
        .empty-state {
            text-align: center;
            padding: 20px;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="container">

        {% if pre_header_rows and pre_header_rows|length > 0 %}
        <div class="metadata">
            {% for line in pre_header_rows %}
            {% if line|trim %}
            <p>{{ line|trim|replace(',', ' ') }}</p>
            {% endif %}
            {% endfor %}
        </div>
        {% endif %}

        {% if transactions and transactions|length > 0 %}
        <table>
            <colgroup>
                {% for column in column_names %}
                    {% if column == '利用日' %}
                    <col class="date-col">
                    {% elif column == 'ご利用店名及び商品名' %}
                    <col class="item-col">
                    {% elif column == '支払区分名称' %}
                    <col class="payment-col">
                    {% elif column == '利用金額' %}
                    <col class="amount-col">
                    {% elif column == '科目＆No.' %}
                    <col class="subject-col">
                    {% elif column == '人数' %}
                    <col class="count-col">
                    {% elif column in ['ID1', 'ID2', 'ID3', 'ID4', 'ID5', 'ID6', 'ID7', 'ID8'] %}
                    <col class="participant-id-col">
                    {% elif column == '備考' %}
                    <col class="notes-col">
                    {% else %}
                    <col>
                    {% endif %}
                {% endfor %}
            </colgroup>
            <thead>
                {# Row 1: Top-level groupings #}
                <tr>
                    {# Columns before attendee group #}
                    {% for column in column_names %}
                        {% if column in ['利用日', 'ご利用店名及び商品名', '利用金額', '科目＆No.', '支払区分名称'] %}
                            <th rowspan="2">{{ column }}</th>
                        {% elif column == '人数' %}
                            {# Start of attendee group: 人数 + 8 ID columns = 9 total #}
                            <th colspan="9" class="attendee-group-header">会議・接待出席者</th>
                        {% endif %}
                        {# Skip ID1-ID8 columns in row 1 (covered by colspan) #}
                        {% if column == '備考' %}
                            <th rowspan="2">{{ column }}</th>
                        {% endif %}
                    {% endfor %}
                </tr>
                {# Row 2: Sub-headers under attendee group #}
                <tr>
                    <th>人数</th>
                    <th colspan="8" class="attendee-subheader">出席者 Participants(ID) → 詳細は次ページ参照</th>
                </tr>
            </thead>
            <tbody>
                {% for transaction in transactions %}
                <tr>
                    {% for column in column_names %}
                    {% if column == '利用金額' and transaction[column] and transaction[column] == transaction[column] %}
                    <td class="amount">¥{{ "{:.0f}".format(transaction[column]) }}</td>
                    {% elif column == '人数' %}
                    {% set value = transaction[column] %}
                    {% if value and value != '' and value != 'nan' and value is not none %}
                    <td class="num">{{ value|int }}</td>
                    {% else %}
                    <td class="num"></td>
                    {% endif %}
                    {% elif column in ['ID1', 'ID2', 'ID3', 'ID4', 'ID5', 'ID6', 'ID7', 'ID8'] %}
                    {% set value = transaction[column] %}
                    <td class="id-value">{{ '' if (value != value or value is none or value == '' or value == 'nan') else value }}</td>
                    {% else %}
                    {% set value = transaction[column] %}
                    <td>{{ '' if (value != value or value is none or value == '' or value == 'nan') else value }}</td>
                    {% endif %}
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <p>該当するトランザクションがありません</p>
        </div>
        {% endif %}

        <h2>出席者詳細</h2>
        {% if unique_attendees and unique_attendees|length > 0 %}
        <table class="attendee-table">
            <thead>
                <tr>
                    <th class="id-col">ID</th>
                    <th>Company</th>
                    <th>Title</th>
                    <th>Name</th>
                </tr>
            </thead>
            <tbody>
                {% for attendee in unique_attendees %}
                <tr>
                    <td class="id-col">{{ attendee['ID'] }}</td>
                    <td>{{ attendee['Company'] }}</td>
                    <td>{{ attendee['Title'] }}</td>
                    <td>{{ attendee['Name'] }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <p>出席者データがありません</p>
        </div>
        {% endif %}
    </div>
</body>
</html>
